POSTGRES_USER=shape_meet
POSTGRES_PASSWORD=shape_meet
POSTGRES_DB=shape_meet
REDIS_PASSWORD=shape_redis
AUTH_SESSION_SECRET=local-debug-secret-please-change
CORS_ORIGIN=*
RUN_SEED=true
SHAPE_DEBUG_ERRORS=true
HOST_BOOTSTRAP_EMAIL=admin@shape.test
HOST_BOOTSTRAP_PASSWORD=ChangeMe123!

ADMIN_HTTP_PORT=13000
NEXT_PUBLIC_APP_URL=http://localhost:13000

LIVEKIT_URL=ws://localhost:17883
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HTTP_PORT=17883
LIVEKIT_USE_EXTERNAL_IP=false
# Reemplaza 127.0.0.1 por la IP LAN real del host cuando LiveKit corre en
# Docker Desktop y el navegador/Tauri corre fuera del contenedor. En macOS:
# ipconfig getifaddr "$(route get default | awk '/interface:/ {print $2}')"
# Si usas Coolify/servidor publico, prefiere LIVEKIT_USE_EXTERNAL_IP=true.
LIVEKIT_NODE_IP=127.0.0.1
LIVEKIT_ENABLE_LOOPBACK_CANDIDATE=true
LIVEKIT_RTC_TCP_PORT=17884
LIVEKIT_RTC_UDP_PORT=17885
LIVEKIT_TURN_DOMAIN=127.0.0.1
LIVEKIT_TURN_REALM=shape-meet-local
LIVEKIT_TURN_SHARED_SECRET=shape-turn-local-secret
LIVEKIT_TURN_TTL_SECONDS=14400
LIVEKIT_TURN_EXTERNAL_IP=127.0.0.1
LIVEKIT_STUN_SERVER=stun.l.google.com:19302
LIVEKIT_TURN_UDP_PORT=13478
LIVEKIT_TURN_TLS_PORT=15349
LIVEKIT_TURN_RELAY_RANGE_START=30000
LIVEKIT_TURN_RELAY_RANGE_END=30100

VITE_SHAPE_API_URL=http://localhost:13000
VITE_SHAPE_APP_URL=http://localhost:1420
VITE_SHAPE_MEETING_URL=http://localhost:1420
VITE_SHAPE_HOST_IDENTIFIER=admin@shape.test
VITE_SHAPE_DEMO_DATA=false
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=shape-meet-admin@0.1.0
NEXT_PUBLIC_SENTRY_RELEASE=shape-meet-admin@0.1.0
SENTRY_DEBUG=true
NEXT_PUBLIC_SENTRY_DEBUG=true
SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=shape-meet-desktop@0.1.0
VITE_SENTRY_DEBUG=true
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

SHAPE_ARTIFACT_STORAGE_DIR=/app/artifacts
SHAPE_ARTIFACT_MAX_BYTES=2147483648
