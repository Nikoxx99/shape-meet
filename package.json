{
  "name": "shape-meet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @shape-meet/desktop --filter @shape-meet/admin dev",
    "dev:ai": "python3 apps/ai-sidecar/server.py --port 7851",
    "dev:ai:demo": "node scripts/run-demo-ai-sidecar.mjs",
    "dev:desktop": "pnpm --filter @shape-meet/desktop tauri:dev",
    "dev:admin": "pnpm --filter @shape-meet/admin dev",
    "build:ai-sidecar": "pnpm --filter @shape-meet/desktop sidecar:build",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @shape-meet/desktop tauri:build",
    "build:admin": "pnpm --filter @shape-meet/admin build",
    "check:native": "pnpm --filter @shape-meet/desktop check:native",
    "desktop:doctor": "node scripts/check-desktop-release.mjs",
    "check:coolify": "node scripts/check-coolify-config.mjs",
    "check:sentry": "node scripts/check-sentry-config.mjs",
    "coolify:env": "node scripts/render-coolify-env.mjs",
    "demo:check": "node scripts/smoke-local-demo.mjs",
    "demo:doctor": "node scripts/run-local-demo-stack.mjs --doctor",
    "demo:ai-runtime": "node scripts/prepare-ai-runtime-demo.mjs",
    "demo:prepare": "node scripts/prepare-local-demo.mjs",
    "demo:up": "node scripts/run-local-demo-stack.mjs",
    "demo:verify": "node scripts/run-local-demo-stack.mjs --verify-ui",
    "demo:ui": "node scripts/smoke-demo-ui.mjs",
    "demo:ui:install": "playwright install chromium",
    "models:runtime": "node scripts/prepare-ai-runtime-models.mjs",
    "smoke:admin": "node scripts/smoke-admin-api.mjs",
    "smoke:launcher": "node scripts/smoke-public-launcher.mjs",
    "smoke:meeting-flow": "node scripts/smoke-meeting-flow.mjs",
    "smoke:ai-contract": "node scripts/smoke-ai-sidecar-contract.mjs",
    "smoke:ai-demo": "node scripts/smoke-ai-demo-processor.mjs",
    "smoke:ai-runtime": "node scripts/smoke-ai-runtime-env.mjs",
    "smoke:ai-model-runtime": "node scripts/smoke-ai-model-runtime-env.mjs",
    "smoke:ai-model-wrappers": "node scripts/smoke-ai-model-wrappers.mjs",
    "smoke:ai-demo-sidecar": "node scripts/smoke-ai-demo-sidecar-runner.mjs",
    "smoke:ai-managed": "node scripts/smoke-ai-managed-processors.mjs",
    "smoke:ai-command": "node scripts/smoke-ai-command-adapters.mjs",
    "smoke:ai-stage-command": "node scripts/smoke-ai-stage-commands.mjs",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "prettier": "latest",
    "typescript": "latest"
  }
}
