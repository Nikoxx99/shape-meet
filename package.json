{
  "name": "shape-meet",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @shape-meet/desktop --filter @shape-meet/admin dev",
    "dev:livekit": "node scripts/run-livekit-dev.mjs",
    "dev:ai": "python3 apps/ai-sidecar/server.py --port 7851",
    "dev:ai:demo": "node scripts/run-demo-ai-sidecar.mjs",
    "dev:ai:demo:daemon": "node scripts/run-demo-ai-sidecar.mjs --daemon",
    "dev:desktop": "pnpm --filter @shape-meet/desktop tauri:dev",
    "dev:admin": "pnpm --filter @shape-meet/admin dev",
    "build:ai-sidecar": "pnpm --filter @shape-meet/desktop sidecar:build",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @shape-meet/desktop tauri:build",
    "build:admin": "pnpm --filter @shape-meet/admin build",
    "check:native": "pnpm --filter @shape-meet/desktop check:native",
    "desktop:ready": "pnpm build:ai-sidecar && node scripts/check-desktop-release.mjs --strict",
    "desktop:doctor": "node scripts/check-desktop-release.mjs",
    "desktop:bundle:check": "node scripts/check-desktop-bundle.mjs",
    "desktop:workflow:check": "node scripts/check-desktop-package-workflow.mjs",
    "desktop:handoff": "node scripts/prepare-desktop-demo-handoff.mjs",
    "desktop:windows-handoff": "node scripts/prepare-windows-demo-handoff.mjs",
    "desktop:config": "node scripts/prepare-desktop-runtime-config.mjs",
    "check:coolify": "node scripts/check-coolify-config.mjs",
    "check:sentry": "node scripts/check-sentry-config.mjs",
    "check:sentry:live": "node scripts/check-sentry-config.mjs --live",
    "sentry:configure": "node scripts/configure-sentry-local.mjs",
    "sentry:cli": "sentry-cli",
    "sentry:info": "sentry-cli info",
    "sentry:issues": "sentry-cli issues list -o arnoproducciones -p luxora --query is:unresolved --max-rows 25",
    "sentry:events": "sentry-cli events list -o arnoproducciones -p luxora --max-rows 25 --show-tags",
    "coolify:env": "node scripts/render-coolify-env.mjs",
    "coolify:handoff": "node scripts/prepare-coolify-handoff.mjs",
    "coolify:deploy": "node scripts/deploy-coolify-app.mjs",
    "demo:check": "node scripts/smoke-local-demo.mjs",
    "demo:debug": "node scripts/export-demo-debug-bundle.mjs",
    "demo:configure-local": "node scripts/configure-local-demo-env.mjs",
    "demo:handoff": "node scripts/package-demo-handoff.mjs",
    "demo:status": "node scripts/report-demo-status.mjs",
    "demo:doctor": "node scripts/run-local-demo-stack.mjs --doctor",
    "demo:ai-runtime": "node scripts/prepare-ai-runtime-demo.mjs",
    "demo:prepare": "node scripts/prepare-local-demo.mjs",
    "demo:up": "node scripts/run-local-demo-stack.mjs",
    "demo:desktop": "node scripts/run-local-demo-stack.mjs --tauri",
    "demo:ready": "node scripts/run-local-demo-stack.mjs --exit-after-ready",
    "demo:verify": "node scripts/run-local-demo-stack.mjs --verify-ui",
    "demo:admin-ui": "node scripts/smoke-admin-ui.mjs",
    "demo:ui": "node scripts/smoke-demo-ui.mjs",
    "demo:ui:install": "playwright install chromium",
    "demo:local-preview": "node scripts/smoke-local-ai-preview.mjs",
    "smoke:debug-bundle": "node scripts/smoke-demo-debug-bundle.mjs",
    "demo:identity:push": "node scripts/push-host-identity.mjs",
    "demo:remote:check": "node scripts/check-remote-demo.mjs",
    "demo:real:check": "node scripts/check-real-demo-readiness.mjs",
    "models:bootstrap": "node scripts/bootstrap-model-workstation.mjs",
    "models:doctor": "node scripts/check-ai-model-runtime.mjs",
    "models:endpoint": "node scripts/run-model-endpoint-server.mjs",
    "models:preflight": "node scripts/preflight-ai-runtime-models.mjs",
    "models:runtime": "node scripts/prepare-ai-runtime-models.mjs",
    "smoke:admin": "node scripts/smoke-admin-api.mjs",
    "smoke:admin-ui": "node scripts/smoke-admin-ui.mjs",
    "smoke:demo-local-config": "node scripts/smoke-local-demo-config.mjs",
    "smoke:launcher": "node scripts/smoke-public-launcher.mjs",
    "smoke:demo-handoff": "node scripts/smoke-demo-handoff.mjs",
    "smoke:demo-status": "node scripts/smoke-demo-status.mjs",
    "smoke:desktop-config": "node scripts/smoke-desktop-runtime-config.mjs",
    "smoke:desktop-workflow": "pnpm desktop:workflow:check -- --json",
    "smoke:desktop-handoff": "node scripts/smoke-desktop-handoff.mjs",
    "smoke:windows-handoff": "node scripts/smoke-windows-demo-handoff.mjs",
    "smoke:livekit-handshake": "node scripts/smoke-livekit-handshake.mjs",
    "smoke:meeting-flow": "node scripts/smoke-meeting-flow.mjs",
    "smoke:sentry-local": "node scripts/smoke-sentry-local-config.mjs",
    "smoke:ai-contract": "node scripts/smoke-ai-sidecar-contract.mjs",
    "smoke:ai-demo": "node scripts/smoke-ai-demo-processor.mjs",
    "smoke:ai-demo-daemon": "node scripts/smoke-ai-demo-daemon.mjs",
    "smoke:ai-runtime": "node scripts/smoke-ai-runtime-env.mjs",
    "smoke:ai-model-bootstrap": "node scripts/smoke-ai-model-bootstrap.mjs",
    "smoke:ai-model-doctor": "node scripts/smoke-ai-model-doctor.mjs",
    "smoke:ai-model-endpoint": "node scripts/smoke-ai-model-endpoint-server.mjs",
    "smoke:ai-model-preflight": "node scripts/smoke-ai-model-preflight.mjs",
    "smoke:ai-model-runtime": "node scripts/smoke-ai-model-runtime-env.mjs",
    "smoke:ai-model-wrappers": "node scripts/smoke-ai-model-wrappers.mjs",
    "smoke:ai-demo-sidecar": "node scripts/smoke-ai-demo-sidecar-runner.mjs",
    "smoke:remote-demo": "node scripts/smoke-remote-demo-check.mjs",
    "smoke:coolify-handoff": "node scripts/smoke-coolify-handoff.mjs",
    "smoke:identity-push": "node scripts/smoke-push-host-identity.mjs",
    "smoke:identity-artifact": "node scripts/smoke-identity-artifact-flow.mjs",
    "smoke:real-demo": "node scripts/smoke-real-demo-readiness.mjs",
    "smoke:ai-managed": "node scripts/smoke-ai-managed-processors.mjs",
    "smoke:ai-command": "node scripts/smoke-ai-command-adapters.mjs",
    "smoke:ai-endpoint": "node scripts/smoke-ai-endpoint-adapters.mjs",
    "smoke:ai-stage-command": "node scripts/smoke-ai-stage-commands.mjs",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@sentry/cli": "^3.6.0",
    "playwright": "^1.61.1",
    "prettier": "latest",
    "typescript": "latest"
  }
}
